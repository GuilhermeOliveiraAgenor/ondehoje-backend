{
  "extends": [
    "@rocketseat/eslint-config/node", 
    "plugin:vitest-globals/recommended"
  ],
  "plugins": [
    "simple-import-sort"
  ],
  "env": {
    "vitest-globals/env": true
  },
  "rules": {
    "no-new": "off",
    "no-useless-constructor": "off",
    "simple-import-sort/imports": "error"
  }
}